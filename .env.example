# ─── Face Attendance System — Environment Configuration ───
# Copy to .env and fill in production values

# Flask
FLASK_ENV=development
SECRET_KEY=generate-a-64-byte-secret-here
JWT_SECRET_KEY=generate-a-64-byte-jwt-secret-here

# Database
DATABASE_URL=postgresql://faceapp:faceapp123@localhost:5432/attendance

# Redis
REDIS_URL=redis://localhost:6379/0

# Face Recognition
FACE_DATA_DIR=./face_data
FACE_MODEL=buffalo_l
LIVENESS_THRESHOLD=0.6

# Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=300

# CORS (comma-separated origins)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Metrics
METRICS_ENABLED=true

# Docker
POSTGRES_PASSWORD=faceapp123
